# ============================================================
#  Visitor Voice Agent — environment configuration (copy to .env)
# ============================================================
# v1 pipeline = OpenAI STT (zh)  →  Claude Haiku 4.5  →  OpenAI TTS
# Every provider is swappable here without touching code.

# ---- Voice architecture（语音架构，提速关键开关）----
# realtime = speech-to-speech 实时模型（默认；真机实测首句 ≈1.4s 明显更快，需 OPENAI_API_KEY 有
#            gpt-realtime 权限）；pipeline = STT→LLM→TTS（便宜、有文字，可回退）。
VOICE_MODE=realtime               # realtime | pipeline
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=marin              # 试不同音色：marin / cedar ...

# ---- LLM "brain" (slot-filling + natural dialogue)；VOICE_MODE=pipeline 时用 ----
# 默认全 OpenAI（只需下面一个 OPENAI_API_KEY 就能跑通整条线路）。
LLM_PROVIDER=openai               # openai | anthropic
LLM_MODEL=gpt-4o-mini             # anthropic 时改 claude-haiku-4-5
# 仅当 LLM_PROVIDER=anthropic 时才需要：
ANTHROPIC_API_KEY=
# 想让客户用"任意模型"：LLM_BASE_URL 指向任一 OpenAI 兼容端点，LLM_MODEL 填该端点模型名，
# OPENAI_API_KEY 填该端点 key。留空=官方 OpenAI。详见 MODELS.md。
#   OpenRouter（GPT/Claude/Gemini/Qwen/Llama/DeepSeek…）: https://openrouter.ai/api/v1
#   阿里 DashScope 兼容:   https://dashscope.aliyuncs.com/compatible-mode/v1
#   DeepSeek: https://api.deepseek.com   | Moonshot: https://api.moonshot.cn/v1
LLM_BASE_URL=

# ---- Speech-to-text (Chinese ASR) ----
STT_PROVIDER=openai               # openai | deepgram(需 pip install livekit-plugins-deepgram)
STT_MODEL=gpt-4o-transcribe       # better zh accuracy than the -mini variant
STT_LANGUAGE=zh

# ---- Text-to-speech (Chinese) ----
# 中文音色升级：TTS_PROVIDER=azure（zh-CN 神经语音，更自然；需 livekit-plugins-azure + AZURE_SPEECH_KEY/REGION）
TTS_PROVIDER=openai               # openai | azure
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy                   # openai: alloy/ash/...；azure: zh-CN-XiaoxiaoNeural
OPENAI_API_KEY=sk-...

# ---- Guard notification channel ----
# none = 保安直接在后台 Dashboard 上点"放行"（零账号，默认，最省事）。
# discord / telegram = 额外推送到群（需各自账号）；wecom = 企业微信（生产）。
NOTIFY_CHANNEL=none                     # none | telegram | wecom | discord（逗号分隔可多渠道，如 telegram,wecom）

# Discord（可选）：频道设置 → 整合 → Webhook → 新建 → 复制 URL
DISCORD_WEBHOOK_URL=

# Telegram：@BotFather 建 bot 拿 token；给 bot 发条消息后用 getUpdates 找 chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# WeCom（企业微信，生产渠道）：群机器人 webhook
WECOM_WEBHOOK_URL=

# ---- Public base URL of the confirm web server (guard taps the link) ----
# Local demo: an ngrok/cloudflared tunnel to the FastAPI server (port 8080).
# ⚠️ Telegram 拒绝 localhost/127.0.0.1 的按钮 URL（整条卡片会发不出）——用 Telegram 时
#    PUBLIC_BASE_URL 必须是手机可达的公网/隧道/局域网地址（如 cloudflared 或 Tailscale IP
#    http://100.x.x.x:8080）。代码已做兜底：URL 不可用时降级为"链接写正文"的纯文本卡片。
PUBLIC_BASE_URL=https://your-tunnel.example.com

# ---- Database (visit + gate-pass records; powers confirm, returning recognition, query) ----
# 本地 demo：SQLite 文件（重启不丢）。生产/永久：换成 Neon Postgres URL 即可，代码不改。
#   生产示例：DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/visitors?sslmode=require
DATABASE_URL=sqlite:///./data/visits.db

# ---- LiveKit (telephony media server) ----
# ☎️ 电话接入需用 LiveKit *Cloud*（本地 dev server 公网打不进来）。详见 TELEPHONY.md。
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...

# ---- Inbound phone (SIP) — 访客拨号 → AI 门卫；用 scripts/setup_sip.sh 一键建 trunk+规则 ----
# 你的入园电话号码（E.164），来自 Twilio/SIP 中继；指到 LiveKit Cloud SIP 主机。见 TELEPHONY.md。
SIP_INBOUND_NUMBER=

# ---- Gate barrier (海康 ISAPI). 留空=demo 用 stub（打印日志）。生产填控制器地址即真实抬杆 ----
HIKVISION_URL=                    # e.g. http://192.168.1.64
HIKVISION_USER=admin
HIKVISION_PASSWORD=
HIKVISION_CHANNEL=1

# ---- Latency tuning (lower = faster replies, 略增打断风险；按实测调) ----
PREEMPTIVE_GENERATION=true        # 抢先生成：用户没说完就开始想，明显降延迟
VAD_MIN_SILENCE=0.4               # 端点静音判定(秒)，越小回应越快
MIN_ENDPOINTING_DELAY=0.4         # 回应前等待(秒)

# ---- Company roster matching (来访单位 自动纠正到园区名单；留空=关闭) ----
# 指向一个 JSON 名单文件即开启（见 roster.example.json）。
ROSTER_PATH=
ROSTER_THRESHOLD=0.55

# ---- Access control: 黑白名单（车牌/手机；留空=关闭）----
# 指向 JSON 文件即开启（见 access.example.json）。黑名单=告警+绝不自动放行；
# 白名单=快速通道。AUTO_PASS_WHITELIST=true 时白名单自动确认+抬杆（默认 false=仍由保安点放行）。
ACCESS_LIST_PATH=
AUTO_PASS_WHITELIST=false

# ---- Misc ----
# Timezone used for the recorded entry time.
TIMEZONE=Asia/Shanghai
# Port for the confirm web server.
WEB_PORT=8080
